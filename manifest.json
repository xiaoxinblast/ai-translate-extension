{
  "manifest_version": 3,
  "name": "AI 翻译助手",
  "version": "1.2.0",
  "description": "基于 DeepSeek V4 的网页翻译插件，支持双语对照、右键翻译、思考模式",
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_title": "AI 翻译助手",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "options_page": "src/options/options.html",
  "background": {
    "service_worker": "src/background/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content/content.js"],
      "css": ["src/content/content.css"],
      "run_at": "document_idle",
      "all_frames": true,
      "match_about_blank": true,
      "match_origin_as_fallback": true
    }
  ],
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "contextMenus",
    "webNavigation"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "web_accessible_resources": [
    {
      "resources": [],
      "matches": ["<all_urls>"]
    }
  ],
  "commands": {
    "translate-page": {
      "suggested_key": { "default": "Ctrl+Shift+T" },
      "description": "翻译当前页面"
    },
    "restore-page": {
      "suggested_key": { "default": "Ctrl+Shift+R" },
      "description": "恢复原文"
    }
  }
}
